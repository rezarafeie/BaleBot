# BotMan PHP Hosting Rules
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /

    DirectoryIndex index.php

    # Redirect index.html to index.php (optional but recommended for PHP hosts)
    RewriteRule ^index\.html$ /index.php [R=301,L]

    # Prevent directory browsing
    Options -Indexes

    # Deny access to sensitive files
    <FilesMatch "^\.env|config\.php|install\.sql|package\.json|vercel\.json">
        Order allow,deny
        Deny from all
    </FilesMatch>

    # Handle webhook with clean URLs
    # Maps /bots/USERNAME/webhook_PLATFORM.php to webhook.php?bot_user=USERNAME&platform=PLATFORM
    RewriteRule ^bots/([a-zA-Z0-9_]+)/webhook_(bale|telegram|rubika)\.php$ webhook.php?bot_user=$1&platform=$2 [QSA,L]
</IfModule>
